{
  "manifest_version": 3,
  "name": "Vinduesrens",
  "version": "0.4",
  "description": "Alerts users to potential data collection like cookie popups.",
"permissions": [
  "storage",
  "activeTab",
  "scripting",
  "notifications",
  "webRequest",
  "webRequestBlocking"
],
"host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icon.png"
  }
}