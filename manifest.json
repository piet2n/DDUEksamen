{
  "manifest_version": 3,
  "name": "Vinduesrens",
  "version": "0.3",
  "description": "Alerts users to potential data collection like cookie popups.",
  "permissions": [
    "activeTab",
    "scripting",
    "notifications",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icon.png"
  }
}