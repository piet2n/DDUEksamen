{
  "manifest_version": 3,
  "name": "Vinduesrens",
  "version": "0.1",
  "description": "Alerts users to potential data collection like cookie popups.",
  "permissions": ["activeTab", "scripting", "notifications"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
    "icons": {
    "128": "icon.png"
  }
}